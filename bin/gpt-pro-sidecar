#!/bin/bash
set -euo pipefail
export PATH="${PATH:+$PATH:}${HOME:+$HOME/.volta/bin:$HOME/.local/bin:}/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

usage() {
  cat <<'USAGE'
gpt-pro-sidecar

Commands:
  gpt-pro-sidecar start [--label <name>] [--project CLI_QUESTIONS] [--github-repo owner/repo|auto] [--timeout <ms>]
  gpt-pro-sidecar flagship <run-dir> [--project CLI_QUESTIONS] [--github-repo owner/repo|auto] [--timeout <ms>]
  gpt-pro-sidecar status <run-dir>
  gpt-pro-sidecar wait <run-dir> [--timeout <ms>] [--show]
  gpt-pro-sidecar show <run-dir>

`start` reads the GPT-PRO prompt from stdin and returns immediately.
`wait` blocks until the run has a receipt and then prints a compact result.
Use `wait --show` or `show` when you want stdout/stderr plus the full answer body.
`flagship` waits for an existing run and sends a final strengthening prompt to the same chat.
USAGE
}

slug() {
  printf '%s' "${1:-run}" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//' \
    | cut -c1-80
}

base_dir() {
  printf '%s\n' "${GPT_PRO_SIDECAR_DIR:-${TMPDIR:-/tmp}/gpt-pro-sidecar}"
}

resolve_gpt_pro() {
  if [[ -n "${GPT_PRO_BIN:-}" && -x "${GPT_PRO_BIN}" ]]; then
    printf '%s\n' "$GPT_PRO_BIN"
    return 0
  fi
  if command -v gpt-pro >/dev/null 2>&1; then
    command -v gpt-pro
    return 0
  fi
  if [[ -n "${HOME:-}" && -x "$HOME/.volta/bin/gpt-pro" ]]; then
    printf '%s\n' "$HOME/.volta/bin/gpt-pro"
    return 0
  fi
  if [[ -n "${HOME:-}" && -x "$HOME/.local/bin/gpt-pro" ]]; then
    printf '%s\n' "$HOME/.local/bin/gpt-pro"
    return 0
  fi
  return 1
}

resolve_node() {
  if [[ -n "${NODE:-}" && -x "${NODE}" ]]; then
    printf '%s\n' "$NODE"
    return 0
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  if [[ -n "${HOME:-}" && -x "$HOME/.volta/bin/node" ]]; then
    printf '%s\n' "$HOME/.volta/bin/node"
    return 0
  fi
  return 1
}

worker_path() {
  local source="${BASH_SOURCE[0]}"
  local dir
  dir="$(cd "$(dirname "$source")" && pwd -P)"
  if [[ -f "$dir/../src/sidecar-worker.js" ]]; then
    printf '%s\n' "$dir/../src/sidecar-worker.js"
    return 0
  fi
  if [[ -f "$dir/../lib/node_modules/gpt-pro-cli/src/sidecar-worker.js" ]]; then
    printf '%s\n' "$dir/../lib/node_modules/gpt-pro-cli/src/sidecar-worker.js"
    return 0
  fi
  return 1
}

start() {
  local label="side-thinking"
  local project="${GPT_PRO_PROJECT:-CLI_QUESTIONS}"
  local timeout="${GPT_PRO_SIDE_TIMEOUT_MS:-900000}"
  local github_repos=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --label)
        label="${2:?missing --label value}"
        shift 2
        ;;
      --project)
        project="${2:?missing --project value}"
        shift 2
        ;;
      --timeout)
        timeout="${2:?missing --timeout value}"
        shift 2
        ;;
      --github-repo)
        github_repos+=("${2:?missing --github-repo value}")
        shift 2
        ;;
      *)
        echo "ERROR unknown start option: $1" >&2
        exit 2
        ;;
    esac
  done

  local gpt_pro_bin
  if ! gpt_pro_bin="$(resolve_gpt_pro)"; then
    echo "ERROR gpt-pro is not available via GPT_PRO_BIN, PATH, or HOME/PATH" >&2
    exit 127
  fi

  local root run_dir prompt_file
  root="$(base_dir)"
  mkdir -p "$root"
  run_dir="$root/$(date -u +%Y%m%dT%H%M%SZ)-$(slug "$label")-$$"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/prompt.md"
  cat > "$prompt_file"
  : > "$run_dir/stdout.txt"
  : > "$run_dir/stderr.txt"
  if [[ ${#github_repos[@]} -gt 0 ]]; then
    printf '%s\n' "${github_repos[@]}" > "$run_dir/github_repos"
  fi
  pwd -P > "$run_dir/cwd"
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "$run_dir/started_at"

  local node_bin worker child_pid
  if ! node_bin="$(resolve_node)"; then
    echo "ERROR node is not available via NODE, PATH, or HOME/PATH" >&2
    exit 127
  fi
  if ! worker="$(worker_path)"; then
    echo "ERROR sidecar worker is missing near ${BASH_SOURCE[0]}" >&2
    exit 127
  fi
  if [[ ${#github_repos[@]} -gt 0 ]]; then
    child_pid="$("$node_bin" "$worker" --detach "$run_dir" "$gpt_pro_bin" "$project" "$timeout" "${github_repos[@]}")"
  else
    child_pid="$("$node_bin" "$worker" --detach "$run_dir" "$gpt_pro_bin" "$project" "$timeout")"
  fi

  printf '%s\n' "$child_pid" > "$run_dir/pid"
  cat <<OUT
OK
run: $run_dir
pid: $child_pid
status: running
OUT
}

status() {
  local run_dir="${1:?missing run-dir}"
  local pid=""
  [[ -f "$run_dir/pid" ]] && pid="$(cat "$run_dir/pid")"
  if [[ -f "$run_dir/exit_code" ]]; then
    local code
    code="$(cat "$run_dir/exit_code")"
    cat <<OUT
DONE
run: $run_dir
exit: $code
stdout: $run_dir/stdout.txt
stderr: $run_dir/stderr.txt
OUT
    print_result_fields "$run_dir"
    return
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
    cat <<OUT
RUNNING
run: $run_dir
pid: $pid
OUT
    local progress
    progress="$(progress_summary "$run_dir" || true)"
    if [[ -n "$progress" ]]; then
      printf 'progress: %s\n' "${progress#status: }"
    fi
    return
  fi
  cat <<OUT
FAILED
run: $run_dir
reason: worker exited before writing exit_code
stdout: $run_dir/stdout.txt
stderr: $run_dir/stderr.txt
OUT
  print_result_fields "$run_dir"
}

field_from_stdout() {
  local run_dir="${1:?missing run-dir}"
  local field="${2:?missing field}"
  [[ -f "$run_dir/stdout.txt" ]] || return 1
  awk -F': ' -v key="$field" '$1 == key {print substr($0, length(key) + 3); exit}' "$run_dir/stdout.txt"
}

error_summary() {
  local run_dir="${1:?missing run-dir}"
  [[ -f "$run_dir/stderr.txt" ]] || return 1
  awk '
    NF {
      lines[++n]=$0
    }
    END {
      if (n >= 2 && lines[1] == "ERROR") print lines[2]
      else if (n >= 1) print lines[1]
    }
  ' "$run_dir/stderr.txt"
}

progress_summary() {
  local run_dir="${1:?missing run-dir}"
  [[ -f "$run_dir/stderr.txt" ]] || return 1
  awk '/^status: / { line=$0 } END { if (line) print line }' "$run_dir/stderr.txt"
}

trim_text() {
  local value="${1:-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

repo_exists() {
  local needle="${1:-}"
  shift || true
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

github_repos_from_stdout() {
  local run_dir="${1:?missing run-dir}"
  local raw part repo
  raw="$(field_from_stdout "$run_dir" "github" || true)"
  [[ -n "$raw" ]] || return 1
  IFS=',' read -ra parts <<< "$raw"
  for part in "${parts[@]}"; do
    repo="$(trim_text "$part")"
    [[ -n "$repo" ]] && printf '%s\n' "$repo"
  done
}

normalize_flagship_github_repos() {
  local run_dir="${1:?missing run-dir}"
  shift || true
  local output=()
  local auto_requested=0
  local repo
  for repo in "$@"; do
    if [[ "$repo" == "auto" ]]; then
      auto_requested=1
      continue
    fi
    if [[ -n "$repo" ]]; then
      if [[ ${#output[@]} -eq 0 ]] || ! repo_exists "$repo" "${output[@]}"; then
        output+=("$repo")
      fi
    fi
  done
  if [[ "$auto_requested" == "1" ]]; then
    local resolved=()
    local resolved_repo
    while IFS= read -r resolved_repo; do
      [[ -n "$resolved_repo" ]] && resolved+=("$resolved_repo")
    done < <(github_repos_from_stdout "$run_dir" || true)
    if [[ ${#resolved[@]} -gt 0 ]]; then
      for repo in "${resolved[@]}"; do
        if [[ -n "$repo" ]]; then
          if [[ ${#output[@]} -eq 0 ]] || ! repo_exists "$repo" "${output[@]}"; then
            output+=("$repo")
          fi
        fi
      done
    elif [[ ${#output[@]} -eq 0 ]] || ! repo_exists "auto" "${output[@]}"; then
      output+=("auto")
    fi
  fi
  if [[ ${#output[@]} -gt 0 ]]; then
    printf '%s\n' "${output[@]}"
  fi
}

result_exit_code() {
  local stdout_file="${1:?missing stdout file}"
  local code="${2:?missing exit code}"
  if [[ "$code" != "0" ]]; then
    printf '%s\n' "$code"
    return 0
  fi
  if [[ -f "$stdout_file" ]] && grep -Eq '^WARN([[:space:]]|$)' "$stdout_file"; then
    printf '10\n'
    return 0
  fi
  local warnings
  warnings="$(awk -F': ' '$1 == "warnings" {print $2; exit}' "$stdout_file" 2>/dev/null || true)"
  if [[ "$warnings" =~ ^[0-9]+$ && "$warnings" -gt 0 ]]; then
    printf '10\n'
    return 0
  fi
  printf '0\n'
}
print_result_fields() {
  local run_dir="${1:?missing run-dir}"
  local answer receipt warnings url project files github error
  answer="$(field_from_stdout "$run_dir" "answer" || true)"
  files="$(field_from_stdout "$run_dir" "files" || true)"
  receipt="$(field_from_stdout "$run_dir" "receipt" || true)"
  project="$(field_from_stdout "$run_dir" "project" || true)"
  github="$(field_from_stdout "$run_dir" "github" || true)"
  warnings="$(field_from_stdout "$run_dir" "warnings" || true)"
  url="$(field_from_stdout "$run_dir" "url" || true)"
  [[ -n "$answer" ]] && printf 'answer: %s\n' "$answer"
  [[ -n "$files" ]] && printf 'files: %s\n' "$files"
  [[ -n "$receipt" ]] && printf 'receipt: %s\n' "$receipt"
  [[ -n "$project" ]] && printf 'project: %s\n' "$project"
  [[ -n "$github" ]] && printf 'github: %s\n' "$github"
  [[ -n "$warnings" ]] && printf 'warnings: %s\n' "$warnings"
  [[ -n "$url" ]] && printf 'url: %s\n' "$url"
  error="$(error_summary "$run_dir" || true)"
  [[ -n "$error" ]] && printf 'error: %s\n' "$error"
  return 0
}

flagship() {
  local run_dir="${1:?missing run-dir}"
  shift || true
  local project="${GPT_PRO_PROJECT:-CLI_QUESTIONS}"
  local timeout="${GPT_PRO_SIDE_TIMEOUT_MS:-900000}"
  local github_repos=()
  if [[ -f "$run_dir/github_repos" ]]; then
    while IFS= read -r repo; do
      [[ -n "$repo" ]] && github_repos+=("$repo")
    done < "$run_dir/github_repos"
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        project="${2:?missing --project value}"
        shift 2
        ;;
      --timeout)
        timeout="${2:?missing --timeout value}"
        shift 2
        ;;
      --github-repo)
        github_repos+=("${2:?missing --github-repo value}")
        shift 2
        ;;
      *)
        echo "ERROR unknown flagship option: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ ! -f "$run_dir/exit_code" ]]; then
    echo "ERROR run is not done yet: $run_dir" >&2
    exit 3
  fi
  if [[ "$(cat "$run_dir/exit_code")" != "0" ]]; then
    echo "ERROR run failed: $run_dir" >&2
    exit 3
  fi

  if [[ ${#github_repos[@]} -gt 0 ]]; then
    local existing_github_repos=("${github_repos[@]}")
    local normalized_repo
    github_repos=()
    while IFS= read -r normalized_repo; do
      [[ -n "$normalized_repo" ]] && github_repos+=("$normalized_repo")
    done < <(normalize_flagship_github_repos "$run_dir" "${existing_github_repos[@]}")
  fi

  local gpt_pro_bin
  if ! gpt_pro_bin="$(resolve_gpt_pro)"; then
    echo "ERROR gpt-pro is not available via GPT_PRO_BIN, PATH, or HOME/PATH" >&2
    exit 127
  fi

  local url answer_file first_answer extra_prompt out_dir prompt_file source_cwd
  url="$(field_from_stdout "$run_dir" "url" || true)"
  answer_file="$(field_from_stdout "$run_dir" "answer" || true)"
  if [[ -z "$url" ]]; then
    echo "ERROR could not find url in $run_dir/stdout.txt" >&2
    exit 3
  fi
  if [[ -n "$answer_file" && -f "$answer_file" ]]; then
    first_answer="$(cat "$answer_file")"
  else
    first_answer="$(cat "$run_dir/stdout.txt")"
  fi
  extra_prompt="$(cat)"
  source_cwd=""
  [[ -f "$run_dir/cwd" ]] && source_cwd="$(cat "$run_dir/cwd" || true)"
  [[ -n "$source_cwd" && ! -d "$source_cwd" ]] && source_cwd=""
  out_dir="$run_dir/flagship-$(date -u +%Y%m%dT%H%M%SZ)"
  mkdir -p "$out_dir"
  prompt_file="$out_dir/prompt.md"
  cat > "$prompt_file" <<PROMPT
You previously gave this answer:

$first_answer

Now do a final flagship pass. Do not merely rephrase. Find the strongest missing distinctions, hidden risks, oversights, and weak spots. Produce the best complete final answer that can survive skeptical implementation/review.

Additional direction from the Codex agent:
$extra_prompt
PROMPT

  set +e
  if [[ ${#github_repos[@]} -gt 0 ]]; then
    local github_args=()
    for repo in "${github_repos[@]}"; do
      github_args+=(--github-repo "$repo")
    done
    if [[ -n "$source_cwd" ]]; then
      (cd "$source_cwd" && "$gpt_pro_bin" ask --session "$url" --project "$project" --timeout "$timeout" "${github_args[@]}" -- "$(cat "$prompt_file")") \
        > "$out_dir/stdout.txt" \
        2> "$out_dir/stderr.txt"
    else
      "$gpt_pro_bin" ask --session "$url" --project "$project" --timeout "$timeout" "${github_args[@]}" -- "$(cat "$prompt_file")" \
        > "$out_dir/stdout.txt" \
        2> "$out_dir/stderr.txt"
    fi
  else
    if [[ -n "$source_cwd" ]]; then
      (cd "$source_cwd" && "$gpt_pro_bin" ask --session "$url" --project "$project" --timeout "$timeout" -- "$(cat "$prompt_file")") \
        > "$out_dir/stdout.txt" \
        2> "$out_dir/stderr.txt"
    else
      "$gpt_pro_bin" ask --session "$url" --project "$project" --timeout "$timeout" -- "$(cat "$prompt_file")" \
        > "$out_dir/stdout.txt" \
        2> "$out_dir/stderr.txt"
    fi
  fi
  local code=$?
  set -e
  code="$(result_exit_code "$out_dir/stdout.txt" "$code")"
  printf '%s\n' "$code" > "$out_dir/exit_code"
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "$out_dir/finished_at"
  cat <<OUT
DONE
run: $out_dir
exit: $code
stdout: $out_dir/stdout.txt
stderr: $out_dir/stderr.txt
OUT
  print_result_fields "$out_dir"
  return "$code"
}

wait_run() {
  local run_dir="${1:?missing run-dir}"
  shift || true
  local timeout_ms="${GPT_PRO_SIDECAR_WAIT_TIMEOUT_MS:-1200000}"
  local show_result=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout)
        timeout_ms="${2:?missing --timeout value}"
        shift 2
        ;;
      --show)
        show_result=1
        shift
        ;;
      *)
        echo "ERROR unknown wait option: $1" >&2
        exit 2
        ;;
    esac
  done
  if [[ ! "$timeout_ms" =~ ^[0-9]+$ ]] || [[ "$timeout_ms" -le 0 ]]; then
    echo "ERROR --timeout must be a positive number of milliseconds" >&2
    exit 2
  fi

  local start_ms now_ms deadline pid code
  start_ms="$(date +%s)000"
  deadline=$((start_ms + timeout_ms))
  while true; do
    if [[ -f "$run_dir/exit_code" ]]; then
      code="$(cat "$run_dir/exit_code")"
      if [[ "$show_result" == "1" ]]; then
        show "$run_dir"
      else
        status "$run_dir"
      fi
      return "$code"
    fi
    pid=""
    [[ -f "$run_dir/pid" ]] && pid="$(cat "$run_dir/pid")"
    if [[ -z "$pid" ]] || ! kill -0 "$pid" >/dev/null 2>&1; then
      status "$run_dir"
      return 3
    fi
    now_ms="$(date +%s)000"
    if [[ "$now_ms" -ge "$deadline" ]]; then
      echo "ERROR wait timed out: $run_dir" >&2
      status "$run_dir" >&2
      return 124
    fi
    sleep 2
  done
}

show() {
  local run_dir="${1:?missing run-dir}"
  echo "== status =="
  status "$run_dir"
  echo
  echo "== stdout =="
  [[ -f "$run_dir/stdout.txt" ]] && cat "$run_dir/stdout.txt" || true
  echo
  echo "== stderr =="
  [[ -f "$run_dir/stderr.txt" ]] && cat "$run_dir/stderr.txt" || true
  local answer_file receipt_file
  answer_file="$(field_from_stdout "$run_dir" "answer" || true)"
  receipt_file="$(field_from_stdout "$run_dir" "receipt" || true)"
  if [[ -n "$answer_file" && -f "$answer_file" ]]; then
    echo
    echo "== answer =="
    cat "$answer_file"
  fi
  if [[ -n "$receipt_file" && -f "$receipt_file" ]]; then
    echo
    echo "== receipt =="
    node -e '
      const fs = require("fs");
      const receipt = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      console.log(`status: ${receipt.status || "unknown"}`);
      console.log(`warnings: ${(receipt.warnings || []).length}`);
      if ((receipt.warnings || []).length) {
        for (const warning of receipt.warnings.slice(0, 5)) console.log(`warning: ${warning}`);
      }
      console.log(`files: ${(receipt.files || []).length}`);
    ' "$receipt_file" || true
  fi
  return 0
}

case "${1:-}" in
  start)
    shift
    start "$@"
    ;;
  flagship)
    shift
    flagship "$@"
    ;;
  status)
    shift
    status "$@"
    ;;
  wait)
    shift
    wait_run "$@"
    ;;
  show)
    shift
    show "$@"
    ;;
  --help|-h|'')
    usage
    ;;
  *)
    echo "ERROR unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
